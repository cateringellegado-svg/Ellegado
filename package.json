{
  "name": "el-legado-catering",
  "version": "2.0.0",
  "description": "El Legado - Catering y Eventos Premium",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --minify",
    "build:css:watch": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --watch",
    "build": "npm run build:css",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "echo 'No linter configured yet'",
    "dev": "npm run build:css:watch"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
