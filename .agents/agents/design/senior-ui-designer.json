  "handoff_protocol": {
    "format": "Figma link + JSON specs",
    "required_fields": ["agent", "phase", "deliverable", "status", "notes", "next_agent", "figma_url", "design_system_url", "asset_manifest", "breakpoints"],
    "approval_required": true,
    "approver": "senior-ux-strategist"
  },
  "priorities": [
    "consistencia-visual",
    "accesibilidad",
    "performance-visual",
    "design-system"
  ],
  "limits": [
    "No define estrategia UX (eso es UX Strategist)",
    "No escribe código de producción",
    "No cambia brand guidelines sin Brand Designer",
    "No comunica directamente con cliente"
