# ============================================
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Mercado Pago
# Get from: https://www.mercadopago.com.ar/developers
# ============================================
# Public key (frontend) - starts with TEST- or APP-
NEXT_PUBLIC_MP_PUBLIC_KEY=your-mp-public-key-here
# Access token (server-side - keep secret) - starts with TEST- or APP-
MP_ACCESS_TOKEN=your-mp-access-token-here
# Test access token (server-side - for development/testing)
MP_ACCESS_TOKEN_TEST=your-mp-access-token-test-here
# Webhook Secret (server-side - for signature validation)
MP_WEBHOOK_SECRET=your-mp-webhook-secret-here

# ============================================
# Vercel Deployment
# Get these from: https://vercel.com/dashboard
# ============================================
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id
VERCEL_TOKEN=your-vercel-token
